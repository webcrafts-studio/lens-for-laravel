{
  "$schema": "https://getcomposer.org/schema.json",
  "name": "webcrafts-studio/lens-for-laravel",
  "description": "A local-first WCAG accessibility auditor for Laravel with axe-core, source mapping, CI workflows, and optional AI fixes.",
  "keywords": [
    "accessibility",
    "axe-core",
    "laravel",
    "wcag"
  ],
  "homepage": "https://lens.webcrafts.pl",
  "type": "library",
  "license": "MIT",
  "support": {
    "docs": "https://lens.webcrafts.pl/docs",
    "issues": "https://github.com/webcrafts-studio/lens-for-laravel/issues",
    "source": "https://github.com/webcrafts-studio/lens-for-laravel"
  },
  "require": {
    "php": "^8.2",
    "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
    "illuminate/routing": "^10.0|^11.0|^12.0|^13.0",
    "spatie/browsershot": "^4.0|^5.0"
  },
  "autoload": {
    "psr-4": {
      "LensForLaravel\\LensForLaravel\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "LensForLaravel\\LensForLaravel\\LensForLaravelServiceProvider"
      ]
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "require-dev": {
    "laravel/pint": "^1.27",
    "laravel/boost": "^2.2",
    "mockery/mockery": "^1.6",
    "orchestra/testbench": "^10.0",
    "pestphp/pest": "^3.0",
    "pestphp/pest-plugin-laravel": "^3.0"
  },
  "suggest": {
    "laravel/ai": "Required only for AI Fix on PHP 8.3+ and Laravel 12+. Core accessibility scanning does not require it."
  },
  "scripts": {
    "test": "vendor/bin/pest",
    "pint": "vendor/bin/pint"
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  }
}
